generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}


model ResumeAnalysis {
  id            Int      @id @default(autoincrement())
  fileName      String
  resumeText    String
  summary       String
  skills        String[]
  missingSkills String[]
  suggestions   String[]
  jobRoles      String[]
  createdAt     DateTime @default(now())
}