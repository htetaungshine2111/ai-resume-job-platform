generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  resumeAnalyses  ResumeAnalysis[]
  jobMatches      JobMatch[]
}


model ResumeAnalysis {
  id            Int      @id @default(autoincrement())
  fileName      String
  resumeText    String
  summary       String
  skills        String[]
  missingSkills String[]
  suggestions   String[]
  jobRoles      String[]
  aiFeedback    String?
  jobDescription String?
  coverLetter    String?
  createdAt     DateTime @default(now())

  userId        Int
  user          User     @relation(fields: [userId], references: [id])
}


model JobMatch {
  id              Int      @id @default(autoincrement())
  resumeText      String
  jobDescription  String
  matchScore      Int
  matchedSkills   String[]
  missingSkills   String[]
  suggestions     String[]
  createdAt       DateTime @default(now())

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}